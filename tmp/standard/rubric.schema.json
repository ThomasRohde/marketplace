{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/earos/rubric.schema.json",
  "title": "EAROS Rubric/Profile Schema",
  "type": "object",
  "required": [
    "rubric_id",
    "version",
    "kind",
    "title",
    "artifact_type",
    "dimensions",
    "scoring",
    "outputs"
  ],
  "properties": {
    "rubric_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "core_rubric",
        "profile",
        "overlay"
      ]
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "candidate",
        "approved",
        "deprecated"
      ]
    },
    "artifact_type": {
      "type": "string"
    },
    "inherits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "purpose": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "viewpoints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applicability": {
      "type": "object"
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "criteria"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "question",
                "metric_type",
                "scale",
                "required_evidence",
                "scoring_guide"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "question": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "metric_type": {
                  "type": "string",
                  "enum": [
                    "ordinal",
                    "binary",
                    "count",
                    "presence",
                    "coverage"
                  ]
                },
                "scale": {
                  "oneOf": [
                    {
                      "type": "array"
                    },
                    {
                      "type": "object"
                    },
                    {
                      "type": "string"
                    }
                  ]
                },
                "weight": {
                  "type": "number"
                },
                "gate": {
                  "oneOf": [
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "object",
                      "required": [
                        "enabled",
                        "severity"
                      ],
                      "properties": {
                        "enabled": {
                          "type": "boolean"
                        },
                        "severity": {
                          "type": "string",
                          "enum": [
                            "advisory",
                            "major",
                            "critical"
                          ]
                        },
                        "failure_effect": {
                          "type": "string"
                        }
                      }
                    }
                  ]
                },
                "required_evidence": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "object",
                        "required": [
                          "id",
                          "description"
                        ],
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "description": {
                            "type": "string"
                          },
                          "examples": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    ]
                  }
                },
                "scoring_guide": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "anti_patterns": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "remediation_hints": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "required": [
        "scale",
        "method",
        "thresholds"
      ],
      "properties": {
        "scale": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "thresholds": {
          "type": "object"
        },
        "na_policy": {
          "type": "string"
        },
        "confidence_policy": {
          "type": "string"
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": [
        "require_evidence_refs",
        "require_confidence",
        "require_actions"
      ],
      "properties": {
        "require_evidence_refs": {
          "type": "boolean"
        },
        "require_confidence": {
          "type": "boolean"
        },
        "require_actions": {
          "type": "boolean"
        },
        "formats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "calibration": {
      "type": "object"
    },
    "change_log": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}